<UserControl x:Class="HspCopier.App.Views.Ball.Weather.NightClearAnimation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="64" Height="64">
    <UserControl.Resources>
        <Storyboard x:Key="EnterStoryboard">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="(UIElement.Opacity)"
                             From="0" To="1" Duration="0:0:0.6"/>
            <DoubleAnimation Storyboard.TargetName="MoonScale"
                             Storyboard.TargetProperty="(ScaleTransform.ScaleX)"
                             From="0.5" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MoonScale"
                             Storyboard.TargetProperty="(ScaleTransform.ScaleY)"
                             From="0.5" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="IdleStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Star1" Storyboard.TargetProperty="(UIElement.Opacity)" From="0.3" To="1" Duration="0:0:1.5"/>
            <DoubleAnimation Storyboard.TargetName="Star2" Storyboard.TargetProperty="(UIElement.Opacity)" From="0.3" To="1" Duration="0:0:2"/>
            <DoubleAnimation Storyboard.TargetName="Star3" Storyboard.TargetProperty="(UIElement.Opacity)" From="0.3" To="1" Duration="0:0:1.8"/>
            <DoubleAnimation Storyboard.TargetName="Star4" Storyboard.TargetProperty="(UIElement.Opacity)" From="0.3" To="1" Duration="0:0:2.2"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="Root" Background="#330A0A20">
        <!-- 月亮(月牙:大圆 + 偏移遮罩) -->
        <Grid Width="28" Height="28" Margin="0,0,6,6" HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="MoonScale" ScaleX="1" ScaleY="1"/>
            </Grid.RenderTransform>
            <Ellipse Width="22" Height="22" Fill="#FFFFF8C0" Stroke="#FFFFE180" StrokeThickness="0.5"/>
            <Ellipse Width="22" Height="22" Fill="#330A0A20" Margin="8,-4,0,0"/>
        </Grid>

        <Ellipse x:Name="Star1" Width="2" Height="2" Margin="-22,-22,0,0" Fill="White"/>
        <Ellipse x:Name="Star2" Width="2" Height="2" Margin="20,-18,0,0" Fill="White"/>
        <Ellipse x:Name="Star3" Width="2" Height="2" Margin="-18,18,0,0" Fill="White"/>
        <Ellipse x:Name="Star4" Width="2" Height="2" Margin="22,16,0,0" Fill="White"/>
    </Grid>
</UserControl>
