<UserControl x:Class="HspCopier.App.Views.Ball.Weather.SunnyAnimation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="64" Height="64">
    <UserControl.Resources>
        <!-- 入场:整体 Opacity 0→1 -->
        <Storyboard x:Key="EnterStoryboard">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="(UIElement.Opacity)"
                             From="0" To="1" Duration="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="RaysScale"
                             Storyboard.TargetProperty="(ScaleTransform.ScaleX)"
                             From="0.4" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RaysScale"
                             Storyboard.TargetProperty="(ScaleTransform.ScaleY)"
                             From="0.4" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <!-- Idle:光线 360° 旋转 -->
        <Storyboard x:Key="IdleStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="RaysRotate"
                             Storyboard.TargetProperty="(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:18"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="Root">
        <!-- 外层缩放入场 -->
        <Grid RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="RaysScale" ScaleX="1" ScaleY="1"/>
            </Grid.RenderTransform>
            <!-- 内层旋转 idle -->
            <Grid RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <RotateTransform x:Name="RaysRotate" Angle="0"/>
                </Grid.RenderTransform>
                <Path Width="56" Height="56" Fill="#FFFFD700" Stroke="#FFFFC400" StrokeThickness="0.5"
                      Data="M 28,4 L 30,14 L 38,10 L 34,18 L 44,16 L 38,24 L 50,26 L 38,28 L 44,36 L 34,32 L 38,40 L 30,38 L 28,52 L 26,38 L 18,40 L 22,32 L 12,36 L 18,28 L 6,26 L 18,24 L 12,16 L 22,18 L 18,10 L 26,14 Z"/>
            </Grid>
        </Grid>
        <Ellipse Width="26" Height="26" Fill="#FFFFD700" Stroke="#FFFFA000" StrokeThickness="1"/>
    </Grid>
</UserControl>
