<UserControl x:Class="HspCopier.App.Views.Ball.Weather.NoLocationAnimation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="64" Height="64">
    <UserControl.Resources>
        <Storyboard x:Key="EnterStoryboard">
            <DoubleAnimation Storyboard.TargetName="PinGroup"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="-20" To="0" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction><BounceEase EasingMode="EaseOut" Bounces="2" Bounciness="3"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="IdleStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="PinGroup"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-4" Duration="0:0:1.5"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="Root">
        <!-- 定位针 -->
        <Grid x:Name="PinGroup" Width="22" Height="30" Margin="0,12,0,0" RenderTransformOrigin="0.5,1">
            <Grid.RenderTransform>
                <TranslateTransform X="0" Y="0"/>
            </Grid.RenderTransform>
            <!-- 水滴形针 -->
            <Path Fill="#FFEF4444" Stroke="#FFB91C1C" StrokeThickness="1"
                  Data="M 11,0 C 4,0 0,5 0,11 C 0,18 11,30 11,30 C 11,30 22,18 22,11 C 22,5 18,0 11,0 Z"/>
            <!-- 中心圆 -->
            <Ellipse Width="8" Height="8" Fill="White" Margin="0,3,0,0"/>
        </Grid>
    </Grid>
</UserControl>
