<UserControl x:Class="HspCopier.App.Views.Ball.Weather.CloudyAnimation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="64" Height="64">
    <UserControl.Resources>
        <Storyboard x:Key="EnterStoryboard">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="(UIElement.Opacity)"
                             From="0" To="1" Duration="0:0:0.6"/>
            <DoubleAnimation Storyboard.TargetName="Cloud1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-30" To="-6" Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Cloud2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="30" To="8" Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="IdleStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Cloud1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-6" To="2" Duration="0:0:5"/>
            <DoubleAnimation Storyboard.TargetName="Cloud2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="8" To="-2" Duration="0:0:6"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="Root">
        <!-- 云1 -->
        <Path x:Name="Cloud1" Width="36" Height="20" Margin="-6,16,0,0" Fill="#FFF5F5F7" Stroke="#FFD0D0D8" StrokeThickness="0.5"
              Data="M 4,16 Q 4,8 12,8 Q 14,2 22,4 Q 30,2 32,10 Q 36,10 36,16 Z"
              RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform><TranslateTransform X="-6" Y="0"/></Path.RenderTransform>
        </Path>
        <!-- 云2 -->
        <Path x:Name="Cloud2" Width="34" Height="18" Margin="8,30,0,0" Fill="#FFE6E6EC" Stroke="#FFB8B8C0" StrokeThickness="0.5"
              Data="M 2,14 Q 2,8 8,8 Q 10,2 18,3 Q 26,2 28,10 Q 32,10 32,14 Z"
              RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform><TranslateTransform X="8" Y="0"/></Path.RenderTransform>
        </Path>
    </Grid>
</UserControl>
